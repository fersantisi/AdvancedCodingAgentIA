# --- Required ---------------------------------------------------------
OPENAI_API_KEY=sk-your-key-here

# --- Optional ----------------------------------------------------------
# Web search (https://tavily.com). Without it, web_search reports
# "not configured" but everything else works.
TAVILY_API_KEY=tvly-your-key-here

# LLM provider and model
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Limits
COMMAND_TIMEOUT_SECONDS=60
MAX_TOOL_ITERATIONS=30
LLM_MAX_RETRIES=3

# Logging
AGENT_LOG_FILE=agent.log

# RAG (index built with: python -m coding_agent.rag.ingest <docs_dir>)
EMBEDDINGS_MODEL=text-embedding-3-small
RAG_STORE_PATH=rag_index.json

# Persistent project memory
AGENT_MEMORY_FILE=.agent/memory.json

# Observability backend ("none" or a provider added in observability/factory.py)
OBSERVABILITY_PROVIDER=none

# Context compaction: summarize history once it exceeds this many messages
COMPACT_AFTER_MESSAGES=60
